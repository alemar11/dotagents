#!/bin/sh
set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
project_dir=$(CDPATH= cd "$script_dir/.." && pwd)
skill_dir=$(CDPATH= cd "$project_dir/../.." && pwd)
manifest="$project_dir/Cargo.toml"

target="${1:-}"

if [ -n "$target" ]; then
  case "$target" in
    aarch64-apple-darwin)
      platform="darwin-arm64"
      ;;
    x86_64-apple-darwin)
      platform="darwin-x86_64"
      ;;
    aarch64-unknown-linux-* | aarch64-linux-*)
      platform="linux-arm64"
      if command -v aarch64-unknown-linux-gnu-gcc >/dev/null 2>&1; then
        export CC_aarch64_unknown_linux_gnu="${CC_aarch64_unknown_linux_gnu:-aarch64-unknown-linux-gnu-gcc}"
        export CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER="${CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER:-aarch64-unknown-linux-gnu-gcc}"
      fi
      ;;
    x86_64-unknown-linux-* | x86_64-linux-*)
      platform="linux-x86_64"
      if command -v x86_64-unknown-linux-gnu-gcc >/dev/null 2>&1; then
        export CC_x86_64_unknown_linux_gnu="${CC_x86_64_unknown_linux_gnu:-x86_64-unknown-linux-gnu-gcc}"
        export CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER="${CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER:-x86_64-unknown-linux-gnu-gcc}"
      fi
      ;;
    *)
      echo "unsupported target triple: $target" >&2
      exit 2
      ;;
  esac

  cargo build --release --manifest-path "$manifest" --target "$target"
  built="$project_dir/target/$target/release/postgres"
else
  cargo build --release --manifest-path "$manifest"
  built="$project_dir/target/release/postgres"

  os=$(uname -s | tr '[:upper:]' '[:lower:]')
  arch=$(uname -m)

  case "$os" in
    darwin | linux)
      ;;
    *)
      echo "unsupported operating system: $os" >&2
      exit 2
      ;;
  esac

  case "$arch" in
    arm64 | aarch64)
      arch="arm64"
      ;;
    x86_64 | amd64)
      arch="x86_64"
      ;;
    *)
      echo "unsupported CPU architecture: $arch" >&2
      exit 2
      ;;
  esac

  platform="$os-$arch"
fi

dest="$skill_dir/scripts/bin/postgres-$platform"
mkdir -p "$(dirname "$dest")"
cp "$built" "$dest"
chmod +x "$dest"

echo "$dest"
